{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "oxc"],
  "env": {
    "es6": true
  },
  "ignorePatterns": ["data/**", "dist/**", "node_modules/**"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "complexity": "off",
    "eslint/complexity": "off",
    "react/react-in-jsx-scope": "off"
  }
}
