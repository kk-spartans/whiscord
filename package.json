{
  "name": "whiscord",
  "private": true,
  "type": "module",
  "module": "src/main.ts",
  "scripts": {
    "dev": "bun run --watch src/main.ts server",
    "start": "bun run src/main.ts server",
    "server": "bun run src/main.ts server",
    "setup": "bun run src/main.ts setup",
    "build:exe": "bun build --compile --minify --bytecode --sourcemap --no-compile-autoload-dotenv --no-compile-autoload-bunfig src/main.ts --outfile dist/whiscord",
    "lint": "oxlint src",
    "fmt": "oxfmt --write src README.md package.json tsconfig.json .gitignore .oxlintrc.json .oxfmtrc.json",
    "fmt:check": "oxfmt --check src README.md package.json tsconfig.json .gitignore .oxlintrc.json .oxfmtrc.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "discord.js": "^14.26.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
